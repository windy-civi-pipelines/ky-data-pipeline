{"legislative_session": "2025RS", "identifier": "HB690", "title": "AN ACT relating to contracts.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Civil Actions", "Contracts", "Labor and Industry", "Personnel and Employment", "Workforce"], "abstracts": [{"note": "Summary of Original Version", "abstract": "Create a new section of KRS Chapter 336 to define \"covenant not to compete\" and \"covered employee\"; provide that an employer shall not require a covered employee to enter into a covenant not to compete; set forth civil remedy, damages that can be recovered, and limitations to bring claim; provide that the provisions must be posted by the employer; indicate that an employer shall not retaliate against an employee for bringing a civil action; establish application of provisions; amend KRS 336.990 to provide civil penalties."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "introduced in House", "date": "2025-02-19T05:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "to Committee on Committees (H)", "date": "2025-02-19T05:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": []}, {"description": "to Economic Development & Workforce Investment (H)", "date": "2025-02-26T05:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": []}], "sponsorships": [], "related_bills": [], "versions": [{"note": "Introduced", "links": [{"url": "https://apps.legislature.ky.gov/recorddocuments/bill/25RS/hb690/orig_bill.pdf", "media_type": "application/pdf"}], "date": "", "classification": ""}], "documents": [], "citations": [], "sources": [{"url": "https://apps.legislature.ky.gov/record/25RS/hb690.html", "note": ""}], "extras": {"BDR": "852"}, "jurisdiction": {"id
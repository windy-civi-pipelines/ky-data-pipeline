{"legislative_session": "2025RS", "identifier": "HB88", "title": "AN ACT relating to waste management districts.", "from_organization": "~{\"classification\": \"lower\"}", "classification": ["bill"], "subject": ["Boards and Commissions", "Consolidated Local Governments", "Effective Dates, Delayed", "Environment and Conservation", "Retroactive Legislation", "Special Districts", "Waste Management"], "abstracts": [{"note": "Summary of Original Version", "abstract": "Amend KRS 109.115 to allow a member serving on a waste management district board in a county containing a consolidated local government to serve until his or her successor is appointed, not to exceed 60 days after the expiration of his or her term; require that the board director's position be vacated after the 60-day period; provide that on the effective date of the Act, any current director on a waste management district board in a county containing a consolidated local government who has exceeded 60 days on the board after expiration of his or her term shall immediately vacate his or her seat; EFFECTIVE January 6, 2026; RETROACTIVE."}], "other_titles": [], "other_identifiers": [], "actions": [{"description": "introduced in House", "date": "2025-01-07T05:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["introduction"], "related_entities": []}, {"description": "to Committee on Committees (H)", "date": "2025-01-07T05:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": []}, {"description": "to Natural Resources & Energy (H)", "date": "2025-02-04T05:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["referral-committee"], "related_entities": []}, {"description": "reported favorably, 1st reading, to Calendar", "date": "2025-02-20T05:00:00+00:00", "organization_id": "~{\"classification\": \"lower\"}", "classification": ["committee-passage"], "related_entities